# Copy to .env and adjust as needed.

# App
PORT=8080
CORS_ORIGINS=https://my-domain.com
SESSION_SECRET=change-me
APP_NAME=Stripez
APP_YEAR=2026

# Oracle
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ORACLE_MODEL=gpt-4o-mini

# Event
STRIPEZ_DEFAULT_DURATION_DAYS=3
STRIPEZ_UNSET_DELAY_HOURS=6
# NOTHING | NUKE | KEEP_DECREES | KEEP_LEDGER | REMOVE_STRIPES_ONLY
STRIPEZ_CLEANUP_ACTION=NOTHING
DRINK_REQUIRE_APPROVAL=true

# Google login (optional)
# Firebase setup:
# 1. Create a Firebase project, go to Settings -> General.
# 2. If it says "There are no apps in your project", click the Web app icon (</>) and register one. Copy and paste the project ID, and the apiKey from the firebaseConfig
# 3. Go to Authentication -> Sign-in method -> enable Google.
FIREBASE_PROJECT_ID=
FIREBASE_API_KEY=
# Optional override allowlist; leave empty for autonomous first-claimer flow
ALLOWED_GOOGLE_EMAILS=

# Storage
DB_FILE=../data/stripez.sqlite

# Admin override (optional but recommended)
ADMIN_KEY=super-secret-admin-key
